# Copy to .env.prod and customize for your environment.

# Image tag pushed by CI/CD (for example: sha-abc1234)
IMAGE_TAG=latest

# Public port served by nginx reverse proxy
PUBLIC_PORT=80

# API logging
LOG_LEVEL=INFO

# MLflow tracking URI (optional)
MLFLOW_TRACKING_URI=mlruns

# Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here
