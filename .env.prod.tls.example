# Copy to .env.prod for TLS-enabled deployment options.

IMAGE_TAG=latest
LOG_LEVEL=INFO
MLFLOW_TRACKING_URI=mlruns

# Option A: Nginx + your own cert files
# Directory must contain:
#   - fullchain.pem
#   - privkey.pem
TLS_CERTS_DIR=./deploy/certs

# Option B: Caddy auto TLS (Let's Encrypt)
DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
